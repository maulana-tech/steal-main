{"noir_version":"0.36.0+801c71880ecf8386a26737a5d8bb5b4cb164b2ab","hash":17854159147479772192,"abi":{"parameters":[{"name":"total_collateral_value_usd","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"total_debt_usd","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},{"name":"positions_collateral","type":{"kind":"array","length":16,"type":{"kind":"integer","sign":"unsigned","width":64}},"visibility":"private"},{"name":"positions_debt","type":{"kind":"array","length":16,"type":{"kind":"integer","sign":"unsigned","width":64}},"visibility":"private"},{"name":"oracle_price_usd","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"}],"return_type":null,"error_types":{}},"bytecode":"","debug_symbols":"","file_map":{"74":{"source":"// Circuit: solvency  [STRETCH GOAL]\n//\n// Proves total pool assets >= total pool liabilities\n// without revealing individual position details.\n//\n// PUBLIC inputs:\n//   total_collateral_value_usd : u64  - aggregated\n//   total_debt_usd             : u64  - aggregated\n//\n// PRIVATE inputs:\n//   positions_collateral : [u64; 16]\n//   positions_debt       : [u64; 16]\n//   oracle_price_usd     : u64\n\nfn main(\n    // --- public ---\n    total_collateral_value_usd: pub u64,\n    total_debt_usd: pub u64,\n\n    // --- private ---\n    positions_collateral: [u64; 16],\n    positions_debt: [u64; 16],\n    oracle_price_usd: u64,\n) {\n    // 1. Sum collateral values\n    let mut sum_collateral_usd: u64 = 0;\n    for i in 0..16 {\n        sum_collateral_usd += (positions_collateral[i] * oracle_price_usd) / 1_000_000;\n    }\n\n    // 2. Sum debts\n    let mut sum_debt: u64 = 0;\n    for i in 0..16 {\n        sum_debt += positions_debt[i];\n    }\n\n    // 3. Verify aggregates match public inputs\n    assert(sum_collateral_usd == total_collateral_value_usd, \"collateral sum mismatch\");\n    assert(sum_debt == total_debt_usd, \"debt sum mismatch\");\n\n    // 4. Pool is solvent: total assets >= total liabilities\n    assert(\n        total_collateral_value_usd >= total_debt_usd,\n        \"pool is insolvent\",\n    );\n}\n","path":"/Users/em/web/steal-main/circuits/solvency/src/main.nr"}},"names":["main"],"brillig_names":["directive_integer_quotient"]}